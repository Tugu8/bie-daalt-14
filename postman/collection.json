        {
          "name": "Create Task",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set(\"testTitle\", \"Test Task \" + Date.now());"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", () => { pm.response.to.have.status(201); });\r",
                  "pm.test(\"Returns id\", () => {\r",
                  "  const d = pm.response.json().data;\r",
                  "  pm.expect(d).to.have.property(\"id\");\r",
                  "  pm.expect(d.id).to.be.a(\"number\");\r",
                  "  pm.environment.set(\"taskId\", d.id);\r",
                  "});\r",
                  "pm.test(\"Title matches\", () => {\r",
                  "  const d = pm.response.json().data;\r",
                  "  pm.expect(d.title).to.include(\"Test Task\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"title\": \"{{testTitle}}\",\r\n  \"priority\": \"high\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tasks"
              ]
            }
          },
          "response": []
        },
